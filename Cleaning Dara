--Making new calculated columns
--Ride Length
ALTER TABLE `new-project-495301`.cyclistic_trips.total_trip_data
ADD COLUMN ride_length_sec int64;

UPDATE `new-project-495301`.cyclistic_trips.total_trip_data
SET ride_length_sec = TIMESTAMP_DIFF(ended_at, started_at, second)
WHERE TRUE;

